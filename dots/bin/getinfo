#!/usr/bin/env bash

# COLORS

c00=$'\e[0;30m'
c01=$'\e[0;31m'
c02=$'\e[0;32m'
c03=$'\e[0;33m'
c04=$'\e[0;34m'
c05=$'\e[0;35m'
c06=$'\e[0;36m'
c07=$'\e[0;37m'
c08=$'\e[0;90m'
c09=$'\e[0;91m'
c10=$'\e[0;92m'
c11=$'\e[0;93m'
c12=$'\e[0;94m'
c13=$'\e[0;95m'
c14=$'\e[0;96m'
c15=$'\e[0;97m'

f0=$'\e[1;30m'
f1=$'\e[1;37m'
rst=$'\e[0m'

# INFO

OS=$(sed '2,$d;s/NAME="//;s/"//' < /etc/os-release)
KERNEL=$(uname -r)
INIT="systemd"
UPTIME=$(awk '
  { gsub(/,/,"")
    if (NF==10) print $3;
    else if (NF==11) print $3,$4;
    else if (NF==12) print $3,$4,$5;
    else print $3,$4,$5,$6 }
  ' <(uptime))
PACKAGES=$(pacman -Q|wc -l)
WM="bspwm"
FONT="Sauce Code Pro Nerd Font Mono"

cat << EOF

${c00}██${c08}██ ${rst}Distro   : ${OS}
${c01}██${c09}██ ${rst}Kernel   : ${KERNEL}
${c02}██${c10}██ ${rst}Init     : ${INIT}
${c03}██${c11}██ ${rst}Uptime   : ${UPTIME}
${c04}██${c12}██ ${rst}Packages : ${PACKAGES}
${c05}██${c13}██ ${rst}WM       : ${WM}
${c06}██${c14}██ ${rst}Shell    : ${SHELL}
${c07}██${c15}██ ${rst}Font     : ${FONT}

EOF
